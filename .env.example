OPENAI_API_KEY=sk-your-openai-key

# Public HTTPS URL from ngrok or your deployed app, without trailing slash.
# Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=

# Optional, but recommended for production-like demos.
TWILIO_AUTH_TOKEN=
VERIFY_TWILIO_SIGNATURE=false

PORT=3000
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin

# Customize what the assistant says and how it behaves for your client demo.
BUSINESS_NAME=Acme Clinic
ASSISTANT_NAME=Ava
ASSISTANT_PURPOSE=help callers book appointments, answer basic business questions, and collect a callback number when needed
